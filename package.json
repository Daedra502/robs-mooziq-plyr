{
  "name": "music-player",
  "version": "0.1.0",
  "description": "A simple, scalable desktop music player with a plug-in visualization system.",
  "main": "src/main/main.js",
  "author": "Rob",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "pack": "electron-builder --dir"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "music-metadata": "^10.6.0"
  },
  "build": {
    "appId": "com.rob.musicplayer",
    "productName": "Music Player",
    "files": [
      "src/**/*",
      "!**/*.log"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "MusicPlayer-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Music Player"
    },
    "portable": {
      "artifactName": "MusicPlayer-Portable-${version}.${ext}"
    }
  }
}
