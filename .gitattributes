# Normalize line endings: store text as LF in the repo, check out native locally.
* text=auto eol=lf

# Treat common binaries as binary (never normalize/diff as text).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.mp3 binary
*.flac binary
*.wav binary
*.ogg binary
*.m4a binary
